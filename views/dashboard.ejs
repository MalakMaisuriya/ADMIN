<!doctype html>
<html class="no-js" lang="en">

<head>
  <meta charset="utf-8">
  <meta http-equiv="x-ua-compatible" content="ie=edge">
  <title>Nozha admin panel - Dashboard</title>
  <meta name="description" content="Nozha admin panel dashboard">
  <meta name="robots" content="noindex, nofollow">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="apple-touch-icon" sizes="180x180" href="/img/favicon/apple-touch-icon.png">
  <link rel="icon" type="image/png" sizes="32x32" href="/img/favicon/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/img/favicon/favicon-16x16.png">
  <link rel="stylesheet" href="/css/normalize.css">
  <link href="/css/fontawsome/all.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.5.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/main.css">
</head>

<body class="admin-page">
  <main class="bmd-layout-content">
    <div class="container py-5">
      <div class="card shade p-4 admin-card">
        <div class="d-flex align-items-center justify-content-between flex-wrap">
          <div>
            <img src="/svg/logo.svg" alt="Nozha" height="80" width="190">
            <h1 class="h4 mt-3 mb-1">Welcome, <%= user.name %></h1>
            <p class="text-muted mb-0"><%= user.email %></p>
            <p class="auth-status mb-0 mt-2">Authenticated with Passport.js Local Strategy</p>
          </div>
          <form method="post" action="/auth/logout" class="mt-3 mt-md-0">
            <a class="btn shade mr-2" href="/norzha-rti-dashboard-master/">Nozha Template</a>
            <a class="btn shade mr-2" href="/users">Users DB</a>
            <button type="submit" class="btn shade f-primary">Logout</button>
          </form>
        </div>
      </div>
    </div>
  </main>
</body>

</html>
