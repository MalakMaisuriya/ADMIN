<!doctype html>
<html class="no-js" lang="en">

<head>
  <meta charset="utf-8">
  <meta http-equiv="x-ua-compatible" content="ie=edge">
  <title>Nozha admin panel - Users Database</title>
  <meta name="description" content="Nozha users database">
  <meta name="robots" content="noindex, nofollow">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="stylesheet" href="/css/normalize.css">
  <link href="/css/fontawsome/all.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.5.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/css/main.css">
</head>

<body class="admin-page">
  <main class="bmd-layout-content">
    <div class="container-fluid py-4">
      <div class="d-flex align-items-center justify-content-between flex-wrap mb-3">
        <div>
          <h1 class="h4 mb-1">Users Database</h1>
          <p class="text-muted mb-0">Passwords are shown as bcrypt hashes only.</p>
        </div>
        <div class="d-flex align-items-center">
          <a class="btn shade mr-2" href="/norzha-rti-dashboard-master/">Nozha Template</a>
          <a class="btn shade mr-2" href="/dashboard">Dashboard</a>
          <form method="post" action="/auth/logout" class="mb-0">
            <button type="submit" class="btn shade f-primary">Logout</button>
          </form>
        </div>
      </div>

      <div class="table-responsive admin-card table-card">
        <table class="table table-bordered table-striped bg-white">
          <thead>
            <tr>
              <th>ID</th>
              <th>Name</th>
              <th>Email</th>
              <th>Password Hash</th>
              <th>Created At</th>
            </tr>
          </thead>
          <tbody>
            <% if (!users.length) { %>
              <tr>
                <td colspan="5" class="text-center text-muted">No users found.</td>
              </tr>
            <% } %>
            <% users.forEach((user) => { %>
              <tr>
                <td><%= user.id %></td>
                <td><%= user.name %></td>
                <td><%= user.email %></td>
                <td><code><%= user.password_hash %></code></td>
                <td><%= user.created_at %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</body>

</html>
